# Git aliases

alias gi="git init"
alias gst="git status"
alias gbls="git branch -a"
alias glog="git log"
alias gpull="git pull"
alias gpush="git push"
alias gpushsu="git push --set-upstream origin"
alias gup="git remote update"
alias gss="git stash save"
alias gsp="git stash pop"
alias gadd="git add"
alias gunst="git reset HEAD --"
alias gcomm="git commit -m"
alias gamend="git commit --amend"
alias gbr="git checkout -b"
alias gbrdel="git branch -d"
alias gco="git checkout"
alias grev="git checkout --"
alias gclone="git clone"
alias gremoteadd="git remote add origin"
alias gtag="git tag -a"
alias gtags="git tag"
alias gtagsup="git push --tags"
alias gtagup="git push origin"
alias gpatchc="git diff >"
alias gpatcha="git apply --stat"
alias gmm="git merge master"
